# =============================================================================
#  maniskill_vit.def
#
#  Singularity container for the ManiSkill + ViT experiments:
#    Heterogeneous Skill Stream (4 tasks) with SAC + ViT-Small (from scratch)
#    validating PALR on large transformer-based policies.
#
#  Conda env: palr_maniskill  (Python 3.10)
#    ManiSkill3 (GPU sim, SAPIEN 3)
#    PyTorch 2.3.1+cu121
#    timm  (ViT-Small from scratch)
#    SAC implementation (custom)
#    Standard analysis + plotting deps
#
#  Build (no root needed with fakeroot):
#    apptainer build maniskill_vit.sif maniskill_vit.def
#    # or:
#    singularity build --fakeroot maniskill_vit.sif maniskill_vit.def
#
#  Run:
#    singularity exec --nv \
#        --bind /home/hzhang/work/rlBigWorld:/workspace \
#        maniskill_vit.sif python maniskill_vit/src/run_experiments.py
#
#  Tasks in the Heterogeneous Skill Stream:
#    1. PickCube-v1       — grasp & place
#    2. StackCube-v1      — precise alignment
#    3. TurnFaucet-v1     — articulated object rotation
#    4. PushCube-v1       — non-prehensile pushing
# =============================================================================

Bootstrap: docker
From: nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

# ---------------------------------------------------------------------------
# Labels
# ---------------------------------------------------------------------------
%labels
    Maintainer        PALR Team
    Version           1.0.0
    Description       ManiSkill + ViT PALR experiments
    CUDA_version      12.1.1
    env               palr_maniskill (Python 3.10)
    PyTorch_version   2.3.1+cu121
    ManiSkill_version 3.x (latest)

# ---------------------------------------------------------------------------
# Runtime environment
# ---------------------------------------------------------------------------
%environment
    export DEBIAN_FRONTEND=noninteractive
    export CONDA_DIR=/opt/miniforge3

    # Default env: palr_maniskill
    export PATH=/opt/miniforge3/envs/palr_maniskill/bin:/opt/miniforge3/bin:$PATH

    # CUDA
    export CUDA_HOME=/usr/local/cuda
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:/usr/local/cuda/extras/CUPTI/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}

    # ManiSkill / SAPIEN headless rendering (EGL)
    export PYOPENGL_PLATFORM=egl
    export EGL_PLATFORM=surfaceless
    export MUJOCO_GL=egl
    unset DISPLAY

    # ManiSkill GPU simulation
    export MS_ASSET_DIR=/workspace/maniskill_vit/assets
    export SAPIEN_HEADLESS=1

    # Performance
    export OMP_NUM_THREADS=4
    export TF_FORCE_GPU_ALLOW_GROWTH=true

# ---------------------------------------------------------------------------
# Build steps
# ---------------------------------------------------------------------------
%post
    set -e
    export DEBIAN_FRONTEND=noninteractive
    export CONDA_DIR=/opt/miniforge3

    # ── 1. System packages ────────────────────────────────────────────────────
    apt-get update -qq
    apt-get install -y --no-install-recommends \
        wget curl git bzip2 unzip ca-certificates \
        build-essential cmake pkg-config patchelf \
        libgl1-mesa-glx libegl1-mesa libgles2-mesa-dev \
        libglfw3 libglfw3-dev \
        libosmesa6 libosmesa6-dev \
        libglew-dev libglib2.0-0 \
        libsm6 libxext6 libxrender1 \
        libx11-6 libxcb1 libxrandr2 libxinerama1 libxcursor1 libxi6 \
        libgomp1 libvulkan1 libvulkan-dev vulkan-tools \
        ffmpeg libjpeg-dev libpng-dev \
        libassimp-dev
    rm -rf /var/lib/apt/lists/*

    # ── 2. Vulkan ICD for NVIDIA (headless) ───────────────────────────────────
    mkdir -p /etc/vulkan/icd.d
    cat > /etc/vulkan/icd.d/nvidia_icd.json << 'EOF'
{
    "file_format_version" : "1.0.0",
    "ICD": {
        "library_path": "libGLX_nvidia.so.0",
        "api_version" : "1.3.0"
    }
}
EOF

    # ── 3. Miniforge ──────────────────────────────────────────────────────────
    wget -q \
        https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh \
        -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p ${CONDA_DIR}
    rm /tmp/miniforge.sh
    . ${CONDA_DIR}/etc/profile.d/conda.sh
    conda update -n base -c conda-forge conda -y --quiet

    # ── 4. Create conda env ───────────────────────────────────────────────────
    conda create -n palr_maniskill python=3.10 pip -y --quiet

    PIP=${CONDA_DIR}/envs/palr_maniskill/bin/pip
    PY=${CONDA_DIR}/envs/palr_maniskill/bin/python

    # ── 5. PyTorch (cu121) ───────────────────────────────────────────────────
    ${PIP} install --quiet \
        torch==2.3.1+cu121 torchvision==0.18.1+cu121 \
        --index-url https://download.pytorch.org/whl/cu121

    # ── 6. ManiSkill3 + SAPIEN ────────────────────────────────────────────────
    # mani-skill pulls in SAPIEN 3.x automatically
    ${PIP} install --quiet mani-skill

    # ── 7. ViT / vision backbone ─────────────────────────────────────────────
    # timm: thousands of pretrained models + clean ViT-Small from scratch
    ${PIP} install --quiet "timm>=0.9.0"

    # ── 8. RL + experiment deps ───────────────────────────────────────────────
    ${PIP} install --quiet \
        "setuptools<81" \
        "numpy<2" scipy matplotlib pandas \
        gymnasium "gym==0.26.2" \
        tensorboard "wandb==0.15.12" \
        imageio imageio-ffmpeg tqdm pyyaml \
        scikit-learn einops

    # ── 9. Cleanup ────────────────────────────────────────────────────────────
    conda clean -afy
    ${PIP} cache purge

    # ── 10. Smoke tests ───────────────────────────────────────────────────────
    echo "=== Smoke test: palr_maniskill ==="
    ${PY} - <<'PYEOF'
import importlib, sys
mods = [
    "torch", "torchvision",
    "mani_skill",
    "timm",
    "numpy", "scipy", "sklearn", "matplotlib", "pandas",
    "gymnasium", "gym",
    "tensorboard", "wandb",
    "imageio", "tqdm", "yaml", "einops",
]
ok = True
for m in mods:
    try:
        mod = importlib.import_module(m)
        v = getattr(mod, "__version__", "n/a")
        print(f"  {m:<25s} {v}")
    except Exception as e:
        print(f"  {m:<25s} FAILED: {e}", file=sys.stderr)
        ok = False
if not ok:
    sys.exit(1)

# Quick ViT-Small from scratch test
import torch, timm
vit = timm.create_model("vit_small_patch16_224", pretrained=False, num_classes=0)
dummy = torch.zeros(1, 3, 128, 128)
# ViT needs 224x224 by default; we'll resize in env wrapper
print(f"  ViT-Small params: {sum(p.numel() for p in vit.parameters())/1e6:.1f}M")
print("palr_maniskill smoke test PASSED")
PYEOF

# ---------------------------------------------------------------------------
# Default runscript
# ---------------------------------------------------------------------------
%runscript
    exec /opt/miniforge3/envs/palr_maniskill/bin/python "$@"

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
%help
    ManiSkill + ViT PALR container.

    Environment: palr_maniskill (Python 3.10)
      PyTorch      2.3.1+cu121
      ManiSkill    3.x  (GPU sim, SAPIEN 3)
      timm         ViT-Small from scratch
      gymnasium    latest

    4-Task Heterogeneous Skill Stream:
      1. PickCube-v1     (grasp & place)
      2. StackCube-v1    (precise alignment)
      3. TurnFaucet-v1   (articulated rotation)
      4. PushCube-v1     (non-prehensile pushing)

    Run experiments:
      singularity exec --nv \
          --bind /home/hzhang/work/rlBigWorld:/workspace \
          maniskill_vit.sif \
          python maniskill_vit/src/run_experiments.py

    Build:
      apptainer build maniskill_vit.sif maniskill_vit.def
